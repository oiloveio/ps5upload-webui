appname=ps5upload-webui
version=3.3.22-6
display_name=PS5Upload WebUI
desc=PS5 局域网传输、安装包安装、挂载和文件管理的 Web UI。内置 ps5upload-engine 二进制，通过伴生服务器（companion）暴露完整 Web 界面，支持 NAS 文件浏览，无需桌面客户端即可使用全部功能。
platform=x86
source=thirdparty

