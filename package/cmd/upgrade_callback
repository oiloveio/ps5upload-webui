#!/bin/bash
set -u

APP_DATA_DIR="${TRIM_PKGVAR:-/tmp/ps5upload-webui}"
CONFIG_DIR="${APP_DATA_DIR}/config"

mkdir -p "${CONFIG_DIR}" "${APP_DATA_DIR}/data" "${APP_DATA_DIR}/logs" 2>/dev/null || true

if [ ! -f "${CONFIG_DIR}/runtime.env" ]; then
    {
        echo "PS5UPLOAD_PS5_IP=${wizard_ps5_ip:-192.168.137.2}"
        echo "PS5UPLOAD_ALLOWED_IPS=${wizard_allow_ip:-}"
    } > "${CONFIG_DIR}/runtime.env"
fi

exit 0
